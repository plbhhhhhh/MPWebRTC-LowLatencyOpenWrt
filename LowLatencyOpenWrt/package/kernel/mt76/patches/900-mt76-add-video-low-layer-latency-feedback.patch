diff --git a/dma.c b/dma.c
index f240016..39d5467 100644
--- a/dma.c
+++ b/dma.c
@@ -368,6 +368,23 @@ mt76_dma_add_buf(struct mt76_dev *dev, struct mt76_queue *q,
 	q->entry[idx].txwi = txwi;
 	q->entry[idx].skb = skb;
 	q->entry[idx].wcid = 0xffff;
+	if (txwi) {
+		struct mt76_txwi_cache *t = txwi;
+		u64 now = ktime_get_ns();
+		struct mt76_tx_cb *cb = skb ? mt76_tx_skb_cb(skb) : NULL;
+		u32 now_us = div_u64(now, NSEC_PER_USEC);
+
+		t->low_layer_start_ns = now;
+		if (cb && cb->low_layer_start_us) {
+			u64 driver_queue =
+				(u32)(now_us - cb->low_layer_start_us) * NSEC_PER_USEC;
+
+			t->low_layer_start_ns -= min_t(u64, driver_queue, now);
+		}
+		t->low_layer_dma_ns = now;
+		t->qid = q->hw_idx;
+		t->low_layer_video = cb && (cb->flags & MT_TX_CB_LOW_LAYER_VIDEO);
+	}
 
 	return idx;
 }

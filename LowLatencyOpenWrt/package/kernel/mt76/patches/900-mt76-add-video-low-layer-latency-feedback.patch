index 9ec6d0b..257d431 100644
--- a/tx.c
+++ b/tx.c
@@ -5,6 +5,50 @@
 
 #include "mt76.h"
 
+void mt76_low_layer_latency_record(struct mt76_dev *dev, u64 start_ns,
+				   u64 dma_ns, u16 wcid, u8 qid,
+				   bool video_flow)
+{
+	u64 now = ktime_get_ns();
+	u64 driver_queue = 0;
+	u64 dma_to_txfree = 0;
+	u64 latency;
+	unsigned long flags;
+
+	if (!start_ns || now <= start_ns)
+		return;
+
+	latency = now - start_ns;
+	if (dma_ns && dma_ns >= start_ns && now > dma_ns) {
+		driver_queue = dma_ns - start_ns;
+		dma_to_txfree = now - dma_ns;
+	}
+
+	if (video_flow)
+		ieee80211_video_low_layer_latency_report(dev->hw, latency);
+
+	spin_lock_irqsave(&dev->low_layer_latency_lock, flags);
+	if (!dev->low_layer_latency_samples)
+		dev->low_layer_latency_ewma_ns = latency;
+	else
+		dev->low_layer_latency_ewma_ns =
+			(dev->low_layer_latency_ewma_ns * 7 + latency) >> 3;
+
+	dev->low_layer_latency_samples++;
+	dev->low_layer_latency_last_ns = latency;
+	dev->low_layer_latency_last_driver_queue_ns = driver_queue;
+	dev->low_layer_latency_last_dma_to_txfree_ns = dma_to_txfree;
+	dev->low_layer_latency_last_start_ns = start_ns;
+	dev->low_layer_latency_last_dma_ns = dma_ns;
+	dev->low_layer_latency_last_end_ns = now;
+	dev->low_layer_latency_last_wcid = wcid;
+	dev->low_layer_latency_last_qid = qid;
+	if (latency > dev->low_layer_latency_max_ns)
+		dev->low_layer_latency_max_ns = latency;
+	spin_unlock_irqrestore(&dev->low_layer_latency_lock, flags);
+}
+EXPORT_SYMBOL_GPL(mt76_low_layer_latency_record);
+

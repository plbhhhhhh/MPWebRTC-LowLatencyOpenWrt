+static int mt76_low_layer_latency_read(struct seq_file *s, void *data)
+{
+	struct mt76_dev *dev = dev_get_drvdata(s->private);
+	unsigned long flags;
+	u64 samples;
+	u64 ewma;
+	u64 max;
+	u64 last;
+	u64 last_driver_queue;
+	u64 last_dma_to_txfree;
+	u64 last_start;
+	u64 last_dma;
+	u64 last_end;
+	u16 last_wcid;
+	u8 last_qid;
+
+	spin_lock_irqsave(&dev->low_layer_latency_lock, flags);
+	samples = dev->low_layer_latency_samples;
+	ewma = dev->low_layer_latency_ewma_ns;
+	max = dev->low_layer_latency_max_ns;
+	last = dev->low_layer_latency_last_ns;
+	last_driver_queue = dev->low_layer_latency_last_driver_queue_ns;
+	last_dma_to_txfree = dev->low_layer_latency_last_dma_to_txfree_ns;
+	last_start = dev->low_layer_latency_last_start_ns;
+	last_dma = dev->low_layer_latency_last_dma_ns;
+	last_end = dev->low_layer_latency_last_end_ns;
+	last_wcid = dev->low_layer_latency_last_wcid;
+	last_qid = dev->low_layer_latency_last_qid;
+	spin_unlock_irqrestore(&dev->low_layer_latency_lock, flags);
+
+	seq_printf(s, "samples=%llu\n", samples);
+	seq_printf(s, "last_us=%llu\n", div_u64(last, NSEC_PER_USEC));
+	seq_printf(s, "ewma_us=%llu\n", div_u64(ewma, NSEC_PER_USEC));
+	seq_printf(s, "max_us=%llu\n", div_u64(max, NSEC_PER_USEC));
+	seq_printf(s, "last_driver_queue_us=%llu\n", div_u64(last_driver_queue, NSEC_PER_USEC));
+	seq_printf(s, "last_dma_to_txfree_us=%llu\n", div_u64(last_dma_to_txfree, NSEC_PER_USEC));
+	seq_printf(s, "last_wcid=%u\n", last_wcid);
+	seq_printf(s, "last_qid=%u\n", last_qid);
+	seq_printf(s, "last_start_ns=%llu\n", last_start);
+	seq_printf(s, "last_dma_ns=%llu\n", last_dma);
+	seq_printf(s, "last_end_ns=%llu\n", last_end);
+
+	return 0;
+}

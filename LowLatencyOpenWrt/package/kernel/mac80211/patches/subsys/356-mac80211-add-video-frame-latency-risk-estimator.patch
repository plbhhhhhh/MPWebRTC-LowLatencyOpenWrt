+static u64 ieee80211_video_low_layer_latency_ns(struct ieee80211_local *local)
+{
+	return min_t(u64, atomic64_read(&local->video_low_layer_latency_ns),
+		     FQ_VIDEO_LOW_LAYER_LATENCY_MAX_NS);
+}
+
+void ieee80211_video_low_layer_latency_report(struct ieee80211_hw *hw,
+					      u64 latency_ns)
+{
+	struct ieee80211_local *local = hw_to_local(hw);
+	u64 samples;
+	u64 old;
+	u64 sample;
+
+	if (!latency_ns)
+		return;
+
+	sample = min_t(u64, latency_ns, FQ_VIDEO_LOW_LAYER_LATENCY_MAX_NS);
+	samples = atomic64_read(&local->video_low_layer_latency_samples);
+	old = atomic64_read(&local->video_low_layer_latency_ns);
+
+	if (!samples)
+		atomic64_set(&local->video_low_layer_latency_ns, sample);
+	else
+		atomic64_set(&local->video_low_layer_latency_ns,
+			     (old * 7 + sample) >> 3);
+
+	atomic64_set(&local->video_last_low_layer_latency_sample_ns, sample);
+	atomic64_inc(&local->video_low_layer_latency_samples);
+}
+EXPORT_SYMBOL_GPL(ieee80211_video_low_layer_latency_report);

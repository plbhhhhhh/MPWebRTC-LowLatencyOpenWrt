+static ssize_t video_frame_interval_us_read(struct file *file,
+					    char __user *user_buf,
+					    size_t count,
+					    loff_t *ppos)
+{
+	struct ieee80211_local *local = file->private_data;
+	char buf[24];
+	u64 interval_us = 0;
+	int len;
+
+	if (READ_ONCE(local->video_frame_interval_fixed))
+		interval_us = div_u64(READ_ONCE(local->video_frame_interval_ns),
+				      NSEC_PER_USEC);
+	len = scnprintf(buf, sizeof(buf), "%llu\n",
+			(unsigned long long)interval_us);
+
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static ssize_t video_frame_interval_us_write(struct file *file,
+					     const char __user *user_buf,
+					     size_t count,
+					     loff_t *ppos)
+{
+	struct ieee80211_local *local = file->private_data;
+	char buf[24];
+	u64 interval_us;
+
+	if (count >= sizeof(buf))
+		return -EINVAL;
+
+	if (copy_from_user(buf, user_buf, count))
+		return -EFAULT;
+
+	if (count && buf[count - 1] == '\n')
+		buf[count - 1] = '\0';
+	else
+		buf[count] = '\0';
+
+	if (kstrtou64(buf, 0, &interval_us))
+		return -EINVAL;
+
+	if (interval_us && (interval_us < 1000 || interval_us > 1000000))
+		return -EINVAL;
+
+	if (interval_us) {
+		WRITE_ONCE(local->video_frame_interval_ns,
+			   interval_us * NSEC_PER_USEC);
+		WRITE_ONCE(local->video_frame_interval_fixed, true);
+	} else {
+		WRITE_ONCE(local->video_frame_interval_ns,
+			   FQ_VIDEO_FRAME_INTERVAL_DEFAULT_NS);
+		WRITE_ONCE(local->video_frame_interval_fixed, false);
+	}
+
+	return count;
+}

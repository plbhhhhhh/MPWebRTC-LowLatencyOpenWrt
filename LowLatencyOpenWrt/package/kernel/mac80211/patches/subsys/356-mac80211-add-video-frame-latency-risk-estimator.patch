+static inline u64 fq_flow_video_quantize_interval(u64 interval)
+{
+	static const u32 fps_modes[] = { 5, 10, 15, 20, 25, 30, 45, 60 };
+	u64 fps;
+	u64 best_diff = ~0ULL;
+	u32 best_fps = 30;
+	int i;
+
+	if (!interval)
+		return FQ_VIDEO_FRAME_INTERVAL_DEFAULT_NS;
+
+	fps = div_u64(1000000000ULL + interval / 2, interval);
+	if (!fps)
+		return FQ_VIDEO_FRAME_INTERVAL_DEFAULT_NS;
+
+	for (i = 0; i < ARRAY_SIZE(fps_modes); i++) {
+		u64 mode = fps_modes[i];
+		u64 diff = fps > mode ? fps - mode : mode - fps;
+
+		if (diff < best_diff) {
+			best_diff = diff;
+			best_fps = fps_modes[i];
+		}
+	}
+
+	return div_u64(1000000000ULL, best_fps);
+}
+
+static inline u64 fq_flow_video_frame_interval(struct fq_flow *flow,
+					       const struct fq_video_pkt_info *info)
+{
+	if (info && info->fixed_frame_interval &&
+	    info->configured_frame_interval_ns)
+		return info->configured_frame_interval_ns;
+
+	if (flow->video_frame_interval_est_ns)
+		return flow->video_frame_interval_est_ns;
+
+	if (info && info->configured_frame_interval_ns)
+		return info->configured_frame_interval_ns;
+
+	return FQ_VIDEO_FRAME_INTERVAL_DEFAULT_NS;
+}
+
+static inline void fq_flow_video_update_interval(struct fq_flow *flow,
+						 const struct fq_video_pkt_info *info,
+						 u64 prev_start_ns,
+						 u64 now)
+{
+	u64 raw_interval;
+
+	if (info && info->fixed_frame_interval)
+		return;
+
+	if (!prev_start_ns || now <= prev_start_ns)
+		return;
+
+	raw_interval = now - prev_start_ns;
+	if (!flow->video_frame_interval_raw_ns)
+		flow->video_frame_interval_raw_ns = raw_interval;
+	else
+		flow->video_frame_interval_raw_ns =
+			(flow->video_frame_interval_raw_ns * 7 + raw_interval) >> 3;
+
+	flow->video_frame_interval_est_ns =
+		fq_flow_video_quantize_interval(flow->video_frame_interval_raw_ns);
+}
+
+static inline u64 fq_flow_video_saturating_add(u64 a, u64 b)
+{
+	if (a > U64_MAX - b)
+		return U64_MAX;
+
+	return a + b;
+}
+
+static inline u64 fq_flow_video_add_clamp(u64 a, u64 b, u64 max,
+						 bool *clamped)
+{
+	u64 sum = fq_flow_video_saturating_add(a, b);
+
+	if (sum > max) {
+		if (clamped)
+			*clamped = true;
+		return max;
+	}
+
+	return sum;
+}
+
+
+static inline u64 fq_flow_video_low_layer_latency(u64 residual)
+{
+	return min_t(u64, residual, FQ_VIDEO_LOW_LAYER_LATENCY_MAX_NS);
+}
+
+static inline void fq_flow_video_store_tail(struct fq_flow *flow,
+					    const struct fq_video_pkt_info *info,
+					    const struct sk_buff *skb,
+					    u64 now)
+{
+	flow->video_last_pkt_ns = now;
+	flow->video_last_pkt_backlog_after_enqueue = flow->backlog;
+	flow->video_last_pkt_enqueue_ns = now;
+	flow->video_last_pkt_len = skb->len;
+}
+
+static inline u64 fq_flow_video_estimate_fq_backlog_delay(struct fq_flow *flow,
+							 const struct fq_video_pkt_info *info,
+							 bool *clamped)
+{
+	u64 tail_backlog_bytes = flow->video_last_pkt_backlog_after_enqueue;
+	u64 frame_queue_bytes = flow->video_frame_queue_bytes ?:
+		flow->video_last_frame_queue_bytes;
+	u64 backlog_bytes;
+	u64 frame_bytes;
+	u64 interval;
+	u64 delay;
+
+	if (clamped)
+		*clamped = false;
+
+	if (!frame_queue_bytes || !tail_backlog_bytes)
+		return 0;
+
+	backlog_bytes = tail_backlog_bytes > frame_queue_bytes ?
+		tail_backlog_bytes - frame_queue_bytes : 0;
+	frame_bytes = flow->video_last_frame_queue_bytes ?:
+		frame_queue_bytes;
+	interval = fq_flow_video_frame_interval(flow, info);
+	delay = mul_u64_u64_div_u64(backlog_bytes, interval, frame_bytes + 1);
+
+	if (delay > FQ_VIDEO_FQ_BACKLOG_DELAY_MAX_NS) {
+		delay = FQ_VIDEO_FQ_BACKLOG_DELAY_MAX_NS;
+		if (clamped)
+			*clamped = true;
+	}
+
+	return delay;
+}
+
+static inline u32 fq_flow_video_add_u32_clamp(u32 a, u32 b)
+{
+	if (a > U32_MAX - b)
+		return U32_MAX;
+
+	return a + b;
+}
+
+static inline u8 fq_flow_video_pending_tail(const struct fq_flow *flow)
+{
+	return (flow->video_pending_frame_head +
+		flow->video_pending_frame_count - 1) % FQ_VIDEO_FRAME_QUEUE_MAX;
+}
+
+static inline bool fq_flow_video_append_frame_segment(struct fq_flow *flow,
+						      u32 frame_id)
+{
+	u8 idx;
+
+	if (flow->video_tracking_degraded)
+		return false;
+
+	if (!frame_id)
+		return false;
+
+	if (flow->video_pending_frame_count >= FQ_VIDEO_FRAME_QUEUE_MAX) {
+		flow->video_tracking_degraded = 1;
+		flow->video_dequeue_frame_guard = 0;
+		flow->video_dequeue_frame_remaining_bytes = 0;
+		flow->video_frame_guard_bytes = 0;
+		return false;
+	}
+
+	idx = (flow->video_pending_frame_head +
+	       flow->video_pending_frame_count) % FQ_VIDEO_FRAME_QUEUE_MAX;
+	flow->video_pending_frame_id[idx] = frame_id;
+	flow->video_pending_frame_bytes[idx] = 0;
+	flow->video_pending_frame_total_bytes[idx] = 0;
+	flow->video_pending_frame_close_ns[idx] = 0;
+	flow->video_pending_frame_pre_ap_latency_ns[idx] = 0;
+	flow->video_pending_frame_fq_backlog_delay_ns[idx] = 0;
+	flow->video_pending_frame_count++;
+
+	return true;
+}
+
+static inline void fq_flow_video_clear_dequeue_frame(struct fq_flow *flow)
+{
+	flow->video_dequeue_frame_id = 0;
+	flow->video_dequeue_frame_guard = 0;
+	flow->video_dequeue_frame_total_bytes = 0;
+	flow->video_dequeue_frame_close_ns = 0;
+	flow->video_dequeue_frame_pre_ap_latency_ns = 0;
+	flow->video_dequeue_frame_fq_backlog_delay_ns = 0;
+	flow->video_frame_guard_bytes = 0;
+}
+
+static inline void fq_flow_video_note_enqueue_bytes(struct fq_flow *flow,
+						    u32 frame_id,
+						    u32 bytes)
+{
+	u8 idx;
+
+	if (!frame_id || !bytes)
+		return;
+
+	if (flow->video_dequeue_frame_id == frame_id) {
+		flow->video_dequeue_frame_remaining_bytes =
+			fq_flow_video_add_u32_clamp(flow->video_dequeue_frame_remaining_bytes,
+						       bytes);
+		flow->video_dequeue_frame_total_bytes =
+			fq_flow_video_add_u32_clamp(flow->video_dequeue_frame_total_bytes,
+						       bytes);
+		if (flow->video_dequeue_frame_guard)
+			flow->video_frame_guard_bytes =
+				fq_flow_video_saturating_add(flow->video_frame_guard_bytes,
+							 bytes);
+		return;
+	}
+
+	if (flow->video_tracking_degraded)
+		return;
+
+	if (!flow->video_pending_frame_count ||
+	    flow->video_pending_frame_id[fq_flow_video_pending_tail(flow)] != frame_id) {
+		if (!fq_flow_video_append_frame_segment(flow, frame_id))
+			return;
+	}
+
+	idx = fq_flow_video_pending_tail(flow);
+	flow->video_pending_frame_bytes[idx] =
+		fq_flow_video_add_u32_clamp(flow->video_pending_frame_bytes[idx], bytes);
+}
+
+static inline u32 fq_flow_video_store_frame_prediction(struct fq_flow *flow,
+						       u32 frame_id,
+						       u64 close_ns,
+						       u64 pre_ap,
+						       u64 fq_backlog_delay,
+						       u32 frame_bytes)
+{
+	u8 i;
+
+	if (!frame_id)
+		return 0;
+
+	if (flow->video_dequeue_frame_id == frame_id &&
+	    flow->video_dequeue_frame_remaining_bytes) {
+		flow->video_dequeue_frame_close_ns = close_ns;
+		flow->video_dequeue_frame_pre_ap_latency_ns = pre_ap;
+		flow->video_dequeue_frame_fq_backlog_delay_ns = fq_backlog_delay;
+		flow->video_dequeue_frame_total_bytes = frame_bytes;
+		return flow->video_dequeue_frame_remaining_bytes;
+	}
+
+	for (i = 0; i < flow->video_pending_frame_count; i++) {
+		u8 idx = (flow->video_pending_frame_head + i) %
+			FQ_VIDEO_FRAME_QUEUE_MAX;
+
+		if (flow->video_pending_frame_id[idx] != frame_id)
+			continue;
+
+		flow->video_pending_frame_close_ns[idx] = close_ns;
+		flow->video_pending_frame_pre_ap_latency_ns[idx] = pre_ap;
+		flow->video_pending_frame_fq_backlog_delay_ns[idx] = fq_backlog_delay;
+		flow->video_pending_frame_total_bytes[idx] = frame_bytes;
+		return flow->video_pending_frame_bytes[idx];
+	}
+
+	return 0;
+}
+
+static inline bool fq_flow_video_load_dequeue_frame(struct fq_flow *flow)
+{
+	u8 idx;
+
+	if (flow->video_dequeue_frame_remaining_bytes)
+		return true;
+
+	flow->video_dequeue_frame_id = 0;
+	flow->video_dequeue_frame_guard = 0;
+	flow->video_dequeue_frame_total_bytes = 0;
+	flow->video_dequeue_frame_close_ns = 0;
+	flow->video_dequeue_frame_pre_ap_latency_ns = 0;
+	flow->video_dequeue_frame_fq_backlog_delay_ns = 0;
+	flow->video_frame_guard_bytes = 0;
+
+	if (!flow->video_pending_frame_count)
+		return false;
+
+	idx = flow->video_pending_frame_head;
+	flow->video_dequeue_frame_id = flow->video_pending_frame_id[idx];
+	flow->video_dequeue_frame_remaining_bytes =
+		flow->video_pending_frame_bytes[idx];
+	flow->video_dequeue_frame_total_bytes =
+		flow->video_pending_frame_total_bytes[idx];
+	flow->video_dequeue_frame_close_ns =
+		flow->video_pending_frame_close_ns[idx];
+	flow->video_dequeue_frame_pre_ap_latency_ns =
+		flow->video_pending_frame_pre_ap_latency_ns[idx];
+	flow->video_dequeue_frame_fq_backlog_delay_ns =
+		flow->video_pending_frame_fq_backlog_delay_ns[idx];
+	flow->video_dequeue_frame_guard = 0;
+
+	flow->video_pending_frame_id[idx] = 0;
+	flow->video_pending_frame_bytes[idx] = 0;
+	flow->video_pending_frame_total_bytes[idx] = 0;
+	flow->video_pending_frame_close_ns[idx] = 0;
+	flow->video_pending_frame_pre_ap_latency_ns[idx] = 0;
+	flow->video_pending_frame_fq_backlog_delay_ns[idx] = 0;
+	flow->video_pending_frame_head =
+		(flow->video_pending_frame_head + 1) % FQ_VIDEO_FRAME_QUEUE_MAX;
+	flow->video_pending_frame_count--;
+
+	return true;
+}
+
+static inline void fq_flow_video_account_remove_bytes(struct fq_flow *flow,
+						      u32 bytes)
+{
+	if (!bytes || !fq_flow_is_video(flow))
+		return;
+
+	fq_flow_video_load_dequeue_frame(flow);
+	if (!flow->video_dequeue_frame_remaining_bytes)
+		return;
+
+	if (flow->video_dequeue_frame_remaining_bytes > bytes)
+		flow->video_dequeue_frame_remaining_bytes -= bytes;
+	else
+		flow->video_dequeue_frame_remaining_bytes = 0;
+
+	if (flow->video_frame_guard_bytes > bytes)
+		flow->video_frame_guard_bytes -= bytes;
+	else
+		flow->video_frame_guard_bytes = 0;
+
+	if (!flow->video_dequeue_frame_remaining_bytes)
+		fq_flow_video_clear_dequeue_frame(flow);
+}
+
+static inline void fq_flow_video_mark_degraded(struct fq_flow *flow)
+{
+	if (!fq_flow_is_video(flow))
+		return;
+
+	flow->video_tracking_degraded = 1;
+	flow->video_dequeue_frame_guard = 0;
+	flow->video_dequeue_frame_remaining_bytes = 0;
+	flow->video_frame_guard_bytes = 0;
+	flow->video_guard_budget_bytes = 0;
+}
+
+static inline bool fq_flow_video_guard_active_at(struct fq_flow *flow,
+						 struct fq_video_dequeue_info *info)
+{
+	u64 now = info ? info->now_ns : ktime_get_ns();
+	u64 fq_wait = 0;
+	u64 low_layer_latency;
+	u64 post_ap_proxy;
+	u64 latency;
+	u64 threshold = info ? info->latency_high_ns : 0;
+	bool clamped = false;
+
+	if (!fq_flow_is_video(flow))
+		return false;
+
+	if (flow->video_tracking_degraded)
+		return false;
+
+	fq_flow_video_load_dequeue_frame(flow);
+	if (!flow->video_dequeue_frame_remaining_bytes)
+		return false;
+
+	if (flow->video_dequeue_frame_close_ns &&
+	    now > flow->video_dequeue_frame_close_ns)

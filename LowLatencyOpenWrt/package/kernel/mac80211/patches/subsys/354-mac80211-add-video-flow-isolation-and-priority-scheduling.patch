diff --git a/net/mac80211/tx.c b/net/mac80211/tx.c
index 38b5a64..bea7af0 100644
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -14,10 +14,15 @@
 #include <linux/slab.h>
 #include <linux/skbuff.h>
 #include <linux/if_vlan.h>
+#include <linux/ip.h>
+#include <linux/ipv6.h>
 #include <linux/etherdevice.h>
 #include <linux/bitmap.h>
 #include <linux/rcupdate.h>
 #include <linux/export.h>
+#include <net/ipv6.h>
+#include <linux/tcp.h>
+#include <linux/udp.h>
 #include <net/net_namespace.h>
 #include <net/ieee80211_radiotap.h>
 #include <net/cfg80211.h>
@@ -1437,6 +1442,72 @@ static void fq_skb_free_func(struct fq *fq,
 	ieee80211_free_txskb(&local->hw, skb);
 }
 
+static bool ieee80211_ports_match(const struct tcphdr *th,
+				 const struct udphdr *uh,
+				 u16 port,
+				 u8 protocol)
+{
+	if (protocol == IPPROTO_TCP)
+		return ntohs(th->source) == port || ntohs(th->dest) == port;
+
+	if (protocol == IPPROTO_UDP)
+		return ntohs(uh->source) == port || ntohs(uh->dest) == port;
+
+	return false;
+}
+
+static bool ieee80211_is_video_skb(struct ieee80211_local *local,
+				      struct sk_buff *skb)
+{
+	struct tcphdr _tcph, *th = NULL;
+	struct udphdr _udph, *uh = NULL;
+	struct ipv6hdr _ip6h, *ip6h;
+	struct iphdr _iph, *iph;
+	unsigned int offset;
+	int nexthdr;
+	u16 video_port;
+
+	video_port = READ_ONCE(local->video_flow_port);
+	if (!video_port)
+		return false;
+
+	switch (skb->protocol) {
+	case htons(ETH_P_IP):
+		offset = skb_network_offset(skb);
+		iph = skb_header_pointer(skb, offset, sizeof(_iph), &_iph);
+		if (!iph || iph->ihl < 5)
+			return false;
+
+		offset += iph->ihl * 4;
+		if (iph->protocol == IPPROTO_UDP)
+			uh = skb_header_pointer(skb, offset, sizeof(_udph), &_udph);
+		else if (iph->protocol == IPPROTO_TCP)
+			th = skb_header_pointer(skb, offset, sizeof(_tcph), &_tcph);
+		else
+			return false;
+
+		return ieee80211_ports_match(th, uh, video_port, iph->protocol);
+	case htons(ETH_P_IPV6):
+		offset = skb_network_offset(skb);
+		ip6h = skb_header_pointer(skb, offset, sizeof(_ip6h), &_ip6h);
+		if (!ip6h)
+			return false;
+
+		offset += sizeof(*ip6h);
+		nexthdr = ipv6_find_hdr(skb, &offset, -1, NULL, NULL);
+		if (nexthdr == IPPROTO_UDP)
+			uh = skb_header_pointer(skb, offset, sizeof(_udph), &_udph);
+		else if (nexthdr == IPPROTO_TCP)
+			th = skb_header_pointer(skb, offset, sizeof(_tcph), &_tcph);
+		else
+			return false;
+
+		return ieee80211_ports_match(th, uh, video_port, nexthdr);
+	default:
+		return false;
+	}
+}
+
 static void ieee80211_txq_enqueue(struct ieee80211_local *local,
 				  struct txq_info *txqi,
 				  struct sk_buff *skb)
@@ -1444,8 +1515,11 @@ static void ieee80211_txq_enqueue(struct ieee80211_local *local,
 	struct fq *fq = &local->fq;
 	struct fq_tin *tin = &txqi->tin;
 	u32 flow_idx;
+	bool is_video;
 
 	ieee80211_set_skb_enqueue_time(skb);
+	is_video = txqi->txq.ac == IEEE80211_AC_BE &&
+		ieee80211_is_video_skb(local, skb);
 
 	spin_lock_bh(&fq->lock);
 	/*
@@ -1460,7 +1534,7 @@ static void ieee80211_txq_enqueue(struct ieee80211_local *local,
 		__skb_queue_tail(&txqi->frags, skb);
 	} else {
 		flow_idx = fq_flow_idx(fq, skb);
-		fq_tin_enqueue(fq, tin, flow_idx, skb,
+		fq_tin_enqueue(fq, tin, flow_idx, skb, is_video,
 			       fq_skb_free_func);
 	}
 	spin_unlock_bh(&fq->lock);

mac80211：增加视频流隔离与优先调度机制

保留 FQ 原有 new_flows 行为，在 BE 队列的旧流阶段增加
video_flows 链表，将配置端口对应的视频流与普通 old_flows 分离。

当 new_flows 为空时，调度器在 video_flows 和 old_flows 之间进行
加权选择，使视频旧流获得更高服务机会，同时避免普通背景旧流长期
饥饿。视频流从 new_flows 进入旧流阶段后使用更大的 DRR 赤字配额。

同时增加 debugfs 配置项，用于在实验中设置需要识别的视频传输端口。

---
diff --git a/include/net/fq.h b/include/net/fq.h
index 99fbe41..88d6c27 100644
--- a/include/net/fq.h
+++ b/include/net/fq.h
@@ -13,6 +13,11 @@
 
 struct fq_tin;
 
+enum fq_flow_class {
+	FQ_FLOW_CLASS_BEST_EFFORT,
+	FQ_FLOW_CLASS_VIDEO,
+};
+
 /**
  * struct fq_flow - per traffic flow queue
  *
@@ -20,13 +25,15 @@ struct fq_tin;
  *	hashes to an index which points to a flow that is already owned by a
  *	different tin the packet is destined to. In such case the implementer
  *	must provide a fallback flow
- * @flowchain: can be linked to fq_tin's new_flows or old_flows. Used for DRR++
+ * @flowchain: can be linked to fq_tin's new_flows, video_flows or old_flows.
+ *	Used for DRR++
  *	(deficit round robin) based round robin queuing similar to the one
  *	found in net/sched/sch_fq_codel.c
  * @queue: sk_buff queue to hold packets
  * @backlog: number of bytes pending in the queue. The number of packets can be
  *	found in @queue.qlen
  * @deficit: used for DRR++
+ * @flow_class: implementation-defined flow priority class
  */
 struct fq_flow {
 	struct fq_tin *tin;
@@ -34,6 +41,7 @@ struct fq_flow {
 	struct sk_buff_head queue;
 	u32 backlog;
 	int deficit;
+	u8 flow_class;
 };
 
 /**
@@ -43,13 +51,17 @@ struct fq_flow {
  * pull interleaved packets out of the associated flows.
  *
  * @new_flows: linked list of fq_flow
+ * @video_flows: linked list of fq_flow
  * @old_flows: linked list of fq_flow
+ * @old_flows_round: weighted round-robin state for old-flow classes
  */
 struct fq_tin {
 	struct list_head new_flows;
+	struct list_head video_flows;
 	struct list_head old_flows;
 	struct list_head tin_list;
 	struct fq_flow default_flow;
+	u8 old_flows_round;
 	u32 backlog_bytes;
 	u32 backlog_packets;
 	u32 overlimit;
diff --git a/include/net/fq_impl.h b/include/net/fq_impl.h
index 9467e33..c7c381c 100644
--- a/include/net/fq_impl.h
+++ b/include/net/fq_impl.h
@@ -11,6 +11,52 @@
 
 /* functions that are embedded into includer */
 
+static inline bool fq_flow_is_video(const struct fq_flow *flow)
+{
+	return flow->flow_class == FQ_FLOW_CLASS_VIDEO;
+}
+
+static inline u32 fq_flow_quantum(const struct fq *fq,
+				  const struct fq_flow *flow)
+{
+	return fq_flow_is_video(flow) ? fq->quantum << 1 : fq->quantum;
+}
+
+static inline struct list_head *fq_flow_old_list(struct fq_tin *tin,
+					 struct fq_flow *flow)
+{
+	return fq_flow_is_video(flow) ? &tin->video_flows : &tin->old_flows;
+}
+
+static inline struct list_head *fq_tin_old_head(struct fq_tin *tin)
+{
+	if (list_empty(&tin->video_flows)) {
+		tin->old_flows_round = 0;
+		return &tin->old_flows;
+	}
+
+	if (list_empty(&tin->old_flows)) {
+		tin->old_flows_round = 0;
+		return &tin->video_flows;
+	}
+
+	return tin->old_flows_round < 2 ? &tin->video_flows : &tin->old_flows;
+}
+
+static inline void fq_tin_next_old_head(struct fq_tin *tin,
+					struct list_head *head)
+{
+	if (list_empty(&tin->video_flows) || list_empty(&tin->old_flows)) {
+		tin->old_flows_round = 0;
+		return;
+	}
+
+	if (head == &tin->video_flows)
+		tin->old_flows_round++;
+	else
+		tin->old_flows_round = 0;
+}
+
 
 static void
 __fq_adjust_removal(struct fq *fq, struct fq_flow *flow, unsigned int packets,
@@ -100,7 +146,7 @@ static struct sk_buff *fq_tin_dequeue(struct fq *fq,
 begin:
 	head = &tin->new_flows;
 	if (list_empty(head)) {
-		head = &tin->old_flows;
+		head = fq_tin_old_head(tin);
 		if (list_empty(head))
 			return NULL;
 	}
@@ -108,9 +154,9 @@ begin:
 	flow = list_first_entry(head, struct fq_flow, flowchain);
 
 	if (flow->deficit <= 0) {
-		flow->deficit += fq->quantum;
-		list_move_tail(&flow->flowchain,
-			       &tin->old_flows);
+		flow->deficit += fq_flow_quantum(fq, flow);
+		list_move_tail(&flow->flowchain, head == &tin->new_flows ?
+			       fq_flow_old_list(tin, flow) : head);
 		goto begin;
 	}
 
@@ -118,8 +164,10 @@ begin:
 	if (!skb) {
 		/* force a pass through old_flows to prevent starvation */
 		if ((head == &tin->new_flows) &&
-		    !list_empty(&tin->old_flows)) {
-			list_move_tail(&flow->flowchain, &tin->old_flows);
+		    (!list_empty(&tin->video_flows) ||
+		     !list_empty(&tin->old_flows))) {
+			list_move_tail(&flow->flowchain,
+				       fq_flow_old_list(tin, flow));
 		} else {
 			list_del_init(&flow->flowchain);
 			flow->tin = NULL;
@@ -127,6 +175,9 @@ begin:
 		goto begin;
 	}
 
+	if (head != &tin->new_flows)
+		fq_tin_next_old_head(tin, head);
+
 	flow->deficit -= skb->len;
 	tin->tx_bytes += skb->len;
 	tin->tx_packets++;
@@ -197,6 +248,7 @@ static struct fq_flow *fq_find_fattest_flow(struct fq *fq)
 static void fq_tin_enqueue(struct fq *fq,
 			   struct fq_tin *tin, u32 idx,
 			   struct sk_buff *skb,
+			   bool is_video,
 			   fq_skb_free_t free_func)
 {
 	struct fq_flow *flow;
@@ -206,6 +258,9 @@ static void fq_tin_enqueue(struct fq *fq,
 	lockdep_assert_held(&fq->lock);
 
 	flow = fq_flow_classify(fq, tin, idx, skb);
+	if (!flow->backlog)
+		flow->flow_class = is_video ? FQ_FLOW_CLASS_VIDEO :
+			FQ_FLOW_CLASS_BEST_EFFORT;
 
 	if (!flow->backlog) {
 		if (flow != &tin->default_flow)
@@ -282,6 +337,8 @@ static void fq_tin_filter(struct fq *fq,
 
 	list_for_each_entry(flow, &tin->new_flows, flowchain)
 		fq_flow_filter(fq, flow, filter_func, filter_data, free_func);
+	list_for_each_entry(flow, &tin->video_flows, flowchain)
+		fq_flow_filter(fq, flow, filter_func, filter_data, free_func);
 	list_for_each_entry(flow, &tin->old_flows, flowchain)
 		fq_flow_filter(fq, flow, filter_func, filter_data, free_func);
 }
@@ -299,11 +356,13 @@ static void fq_flow_reset(struct fq *fq,
 	if (!list_empty(&flow->flowchain)) {
 		list_del_init(&flow->flowchain);
 		if (list_empty(&tin->new_flows) &&
+		    list_empty(&tin->video_flows) &&
 		    list_empty(&tin->old_flows))
 			list_del_init(&tin->tin_list);
 	}
 
 	flow->tin = NULL;
+	flow->flow_class = FQ_FLOW_CLASS_BEST_EFFORT;
 
 	WARN_ON_ONCE(flow->backlog);
 }
@@ -318,7 +377,7 @@ static void fq_tin_reset(struct fq *fq,
 	for (;;) {
 		head = &tin->new_flows;
 		if (list_empty(head)) {
-			head = &tin->old_flows;
+			head = fq_tin_old_head(tin);
 			if (list_empty(head))
 				break;
 		}
@@ -336,13 +395,16 @@ static void fq_flow_init(struct fq_flow *flow)
 {
 	INIT_LIST_HEAD(&flow->flowchain);
 	__skb_queue_head_init(&flow->queue);
+	flow->flow_class = FQ_FLOW_CLASS_BEST_EFFORT;
 }
 
 static void fq_tin_init(struct fq_tin *tin)
 {
 	INIT_LIST_HEAD(&tin->new_flows);
+	INIT_LIST_HEAD(&tin->video_flows);
 	INIT_LIST_HEAD(&tin->old_flows);
 	INIT_LIST_HEAD(&tin->tin_list);
+	tin->old_flows_round = 0;
 	fq_flow_init(&tin->default_flow);
 }
 

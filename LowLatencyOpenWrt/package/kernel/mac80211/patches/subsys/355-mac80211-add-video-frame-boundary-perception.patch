mac80211：增加视频帧边界感知机制

针对已识别的视频流，在入队路径基于 AP 可见的包长序列维护轻量级
帧状态，不读取视频载荷，也不依赖应用侧显式帧编号。

AVG 模式检测器将包长映射到粗粒度区间，当同一视频流内连续包长
从一个稳定区间切换到另一个区间时，将其作为候选帧边界。

LAST 模式检测器识别多个接近 MTU 的大包后出现的小尾包，并将该
小包作为当前帧结束信号。对于暂时无法匹配 AVG/LAST 特征的流，
保留包数量和时间阈值作为降级边界。
---
diff --git a/include/net/fq.h b/include/net/fq.h
index 88d6c27..0fab712 100644
--- a/include/net/fq.h
+++ b/include/net/fq.h
@@ -18,6 +18,49 @@ enum fq_flow_class {
 	FQ_FLOW_CLASS_VIDEO,
 };
 
+#define FQ_VIDEO_FRAME_MAX_PACKETS	1024
+#define FQ_VIDEO_FRAME_TIMEOUT_NS	100000000ULL
+#define FQ_VIDEO_AVG_BUCKET_SHIFT	6
+#define FQ_VIDEO_AVG_MIN_PACKETS	3
+#define FQ_VIDEO_AVG_CHANGE_PCT	15
+#define FQ_VIDEO_LAST_LARGE_MIN_BYTES	1100
+#define FQ_VIDEO_LAST_TAIL_MAX_BYTES	900
+#define FQ_VIDEO_LAST_MIN_PACKETS	3
+#define FQ_VIDEO_MODE_LOCK_EVENTS	3
+
+enum fq_video_frame_event {
+	FQ_VIDEO_FRAME_EVENT_NONE,
+	FQ_VIDEO_FRAME_EVENT_FALLBACK_PACKETS = 1 << 0,
+	FQ_VIDEO_FRAME_EVENT_FALLBACK_TIMEOUT = 1 << 1,
+	FQ_VIDEO_FRAME_EVENT_AVG_BOUNDARY = 1 << 2,
+	FQ_VIDEO_FRAME_EVENT_LAST_BOUNDARY = 1 << 3,
+};
+
+enum fq_video_frame_mode {
+	FQ_VIDEO_FRAME_MODE_UNKNOWN,
+	FQ_VIDEO_FRAME_MODE_AVG,
+	FQ_VIDEO_FRAME_MODE_LAST,
+};
+
+/**
+ * struct fq_video_pkt_info - observable video packet metadata
+ *
+ * @is_video: packet belongs to an implementation-defined video flow
+ * @has_size: packet has queue-visible size metadata for frame sensing
+ * @last_tail_candidate: packet size is small enough to be a LAST tail
+ * @size_bucket: coarse packet-size bucket used by AVG mode
+ * @pkt_len: IP packet length used by AVG/LAST sensing
+ * @enqueue_time_ns: timestamp sampled before enqueue
+ */
+struct fq_video_pkt_info {
+	bool is_video;
+	bool has_size;
+	bool last_tail_candidate;
+	u32 size_bucket;
+	u32 pkt_len;
+	u64 enqueue_time_ns;
+};
+
 /**
  * struct fq_flow - per traffic flow queue
  *
@@ -34,6 +78,20 @@ enum fq_flow_class {
  *	found in @queue.qlen
  * @deficit: used for DRR++
  * @flow_class: implementation-defined flow priority class
+ * @video_frame_id: incrementing frame id for AVG/LAST size perception
+ * @video_frame_packets: packets seen in the currently open video frame
+ * @video_frame_bytes: bytes seen in the currently open video frame
+ * @video_frame_size_bucket: AVG packet-size bucket of the current frame
+ * @video_frame_mode: learned AVG/LAST mode for this flow
+ * @video_frame_mode_hits: consecutive boundary hits for mode locking
+ * @video_last_frame_packets: packets seen in the last completed video frame
+ * @video_last_frame_bytes: bytes seen in the last completed video frame
+ * @video_frame_start_ns: enqueue time of the first packet in current frame
+ * @video_last_pkt_ns: enqueue time of the latest video packet in this flow
+ * @video_last_frame_end_ns: enqueue time used for latest frame completion
+ * @video_last_frame_interval_ns: interval between latest two completed frames
+ * @video_frame_open: whether a current frame is being tracked
+ * @video_last_pkt_is_frame_end: whether latest video packet ended a frame
  */
 struct fq_flow {
 	struct fq_tin *tin;
@@ -41,7 +97,21 @@ struct fq_flow {
 	struct sk_buff_head queue;
 	u32 backlog;
 	int deficit;
+	u32 video_frame_id;
+	u32 video_frame_packets;
+	u32 video_frame_bytes;
+	u32 video_frame_size_bucket;
+	u32 video_last_frame_packets;
+	u32 video_last_frame_bytes;
+	u64 video_frame_start_ns;
+	u64 video_last_pkt_ns;
+	u64 video_last_frame_end_ns;
+	u64 video_last_frame_interval_ns;
 	u8 flow_class;
+	u8 video_frame_mode;
+	u8 video_frame_mode_hits;
+	u8 video_frame_open;
+	u8 video_last_pkt_is_frame_end;
 };
 
 /**
diff --git a/include/net/fq_impl.h b/include/net/fq_impl.h
index c7c381c..af8e8b9 100644
--- a/include/net/fq_impl.h
+++ b/include/net/fq_impl.h
@@ -57,6 +57,159 @@ static inline void fq_tin_next_old_head(struct fq_tin *tin,
 		tin->old_flows_round = 0;
 }
 
+static inline bool fq_video_len_changed(u32 len, u32 ref, u32 pct)
+{
+	u32 diff;
+
+	if (!len || !ref)
+		return false;
+
+	diff = len > ref ? len - ref : ref - len;
+	return diff * 100 >= ref * pct;
+}
+
+static inline bool fq_video_last_tail_candidate(struct fq_flow *flow, u32 len)
+{
+	return flow->video_frame_packets >= FQ_VIDEO_LAST_MIN_PACKETS &&
+	       flow->video_frame_bytes / flow->video_frame_packets >=
+		       FQ_VIDEO_LAST_LARGE_MIN_BYTES &&
+	       len <= FQ_VIDEO_LAST_TAIL_MAX_BYTES;
+}
+
+static inline bool fq_flow_video_mode_locked(struct fq_flow *flow)
+{
+	return flow->video_frame_mode != FQ_VIDEO_FRAME_MODE_UNKNOWN &&
+	       flow->video_frame_mode_hits >= FQ_VIDEO_MODE_LOCK_EVENTS;
+}
+
+static inline bool fq_flow_video_mode_allows(struct fq_flow *flow,
+						    u8 mode)
+{
+	return !fq_flow_video_mode_locked(flow) ||
+	       flow->video_frame_mode == mode;
+}
+
+static inline void fq_flow_video_note_mode(struct fq_flow *flow, u8 mode)
+{
+	if (flow->video_frame_mode == mode) {
+		if (flow->video_frame_mode_hits < U8_MAX)
+			flow->video_frame_mode_hits++;
+	} else {
+		flow->video_frame_mode = mode;
+		flow->video_frame_mode_hits = 1;
+	}
+}
+
+static inline void fq_flow_video_reset(struct fq_flow *flow)
+{
+	flow->video_frame_id = 0;
+	flow->video_frame_packets = 0;
+	flow->video_frame_bytes = 0;
+	flow->video_frame_size_bucket = 0;
+	flow->video_frame_mode = FQ_VIDEO_FRAME_MODE_UNKNOWN;
+	flow->video_frame_mode_hits = 0;
+	flow->video_last_frame_packets = 0;
+	flow->video_last_frame_bytes = 0;
+	flow->video_frame_start_ns = 0;
+	flow->video_last_pkt_ns = 0;
+	flow->video_last_frame_end_ns = 0;
+	flow->video_last_frame_interval_ns = 0;
+	flow->video_frame_open = 0;
+	flow->video_last_pkt_is_frame_end = 0;
+}
+
+static inline void fq_flow_video_start_frame(struct fq_flow *flow,
+					     const struct fq_video_pkt_info *info,
+					     u64 now)
+{
+	flow->video_frame_id++;
+	flow->video_frame_packets = 0;
+	flow->video_frame_bytes = 0;
+	flow->video_frame_size_bucket = info->size_bucket;
+	flow->video_frame_start_ns = now;
+	flow->video_frame_open = 1;
+	flow->video_last_pkt_is_frame_end = 0;
+}
+
+static inline void fq_flow_video_complete_frame(struct fq_flow *flow,
+						 u64 now)
+{
+	flow->video_last_frame_packets = flow->video_frame_packets;
+	flow->video_last_frame_bytes = flow->video_frame_bytes;
+	if (flow->video_last_frame_end_ns)
+		flow->video_last_frame_interval_ns =
+			now - flow->video_last_frame_end_ns;
+	flow->video_last_frame_end_ns = now;
+	flow->video_frame_open = 0;
+	flow->video_last_pkt_is_frame_end = 1;
+}
+
+static inline u8 fq_flow_video_update(struct fq_flow *flow,
+				      const struct fq_video_pkt_info *info,
+				      const struct sk_buff *skb)
+{
+	u8 event = FQ_VIDEO_FRAME_EVENT_NONE;
+	u64 now;
+	u32 bytes;
+	bool avg_boundary = false;
+	bool last_boundary = false;
+
+	if (!info || !info->is_video || !info->has_size || !skb)
+		return event;
+
+	now = info->enqueue_time_ns;
+	bytes = info->pkt_len;
+
+	if (flow->video_frame_open && !flow->video_last_pkt_is_frame_end) {
+		last_boundary = fq_flow_video_mode_allows(flow,
+			FQ_VIDEO_FRAME_MODE_LAST) &&
+			info->last_tail_candidate &&
+			fq_video_last_tail_candidate(flow, bytes);
+		if (!last_boundary &&
+		    fq_flow_video_mode_allows(flow, FQ_VIDEO_FRAME_MODE_AVG) &&
+		    flow->video_frame_size_bucket != info->size_bucket &&
+		    flow->video_frame_packets >= FQ_VIDEO_AVG_MIN_PACKETS) {
+			avg_boundary = fq_video_len_changed(bytes,
+				flow->video_frame_bytes / flow->video_frame_packets,
+				FQ_VIDEO_AVG_CHANGE_PCT);
+		}
+
+		if (avg_boundary) {
+			fq_flow_video_complete_frame(flow,
+				flow->video_last_pkt_ns ?: now);
+			fq_flow_video_note_mode(flow, FQ_VIDEO_FRAME_MODE_AVG);
+			event |= FQ_VIDEO_FRAME_EVENT_AVG_BOUNDARY;
+		} else if (!last_boundary) {
+			if (flow->video_frame_packets >= FQ_VIDEO_FRAME_MAX_PACKETS) {
+				fq_flow_video_complete_frame(flow,
+					flow->video_last_pkt_ns ?: now);
+				event |= FQ_VIDEO_FRAME_EVENT_FALLBACK_PACKETS;
+			} else if (flow->video_frame_start_ns &&
+				   now - flow->video_frame_start_ns >=
+				   FQ_VIDEO_FRAME_TIMEOUT_NS) {
+				fq_flow_video_complete_frame(flow,
+					flow->video_last_pkt_ns ?: now);
+				event |= FQ_VIDEO_FRAME_EVENT_FALLBACK_TIMEOUT;
+			}
+		}
+	}
+
+	if (!flow->video_frame_open || flow->video_last_pkt_is_frame_end)
+		fq_flow_video_start_frame(flow, info, now);
+
+	flow->video_frame_packets++;
+	flow->video_frame_bytes += bytes;
+	flow->video_last_pkt_ns = now;
+
+	if (last_boundary) {
+		fq_flow_video_complete_frame(flow, now);
+		fq_flow_video_note_mode(flow, FQ_VIDEO_FRAME_MODE_LAST);
+		event |= FQ_VIDEO_FRAME_EVENT_LAST_BOUNDARY;
+	}
+
+	return event;
+}
+
 

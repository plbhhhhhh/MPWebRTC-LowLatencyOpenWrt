-	if (!flow->backlog)
-		flow->flow_class = is_video ? FQ_FLOW_CLASS_VIDEO :
-			FQ_FLOW_CLASS_BEST_EFFORT;
+	enqueue_flow = flow;
+	flow_class = is_video ? FQ_FLOW_CLASS_VIDEO :
+		FQ_FLOW_CLASS_BEST_EFFORT;
+	if (!flow->backlog) {
+		if (flow->flow_class != flow_class)
+			fq_flow_video_reset(flow);
+		flow->flow_class = flow_class;
+	}
 
 	if (!flow->backlog) {
 		if (flow != &tin->default_flow)
@@ -290,10 +421,10 @@ static void fq_tin_enqueue(struct fq *fq,
 	while (fq->backlog > fq->limit || oom) {
 		flow = fq_find_fattest_flow(fq);
 		if (!flow)
-			return;
+			return video_event;
 
 		if (!fq_flow_drop(fq, flow, free_func))
-			return;
+			return video_event;
 
 		flow->tin->overlimit++;
 		fq->overlimit++;
@@ -302,6 +433,22 @@ static void fq_tin_enqueue(struct fq *fq,
 			oom = (fq->memory_usage > fq->memory_limit);
 		}
 	}
+
+	if (skb_peek_tail(&enqueue_flow->queue) == enqueue_skb)
+		video_event = fq_flow_video_update(enqueue_flow, video_info,
+						   enqueue_skb);
+
+	return video_event;
+}
+
+static inline void fq_tin_enqueue(struct fq *fq,
+				  struct fq_tin *tin, u32 idx,
+				  struct sk_buff *skb,
+				  bool is_video,
+				  fq_skb_free_t free_func)
+{
+	fq_tin_enqueue_video_info(fq, tin, idx, skb, is_video, NULL,
+				  free_func);
 }
 
 static void fq_flow_filter(struct fq *fq,
@@ -363,6 +509,7 @@ static void fq_flow_reset(struct fq *fq,
 
 	flow->tin = NULL;
 	flow->flow_class = FQ_FLOW_CLASS_BEST_EFFORT;
+	fq_flow_video_reset(flow);
 
 	WARN_ON_ONCE(flow->backlog);
 }

+static inline u32 ieee80211_video_size_bucket(u32 len)
+{
+	return len >> FQ_VIDEO_AVG_BUCKET_SHIFT;
+}
+
+static inline u32 ieee80211_video_effective_len(struct sk_buff *skb,
+						u32 pkt_len)
+{
+	if (skb_is_gso(skb) && skb_shinfo(skb)->gso_size)
+		return skb_shinfo(skb)->gso_size;
+
+	return pkt_len;
+}
+
+static void ieee80211_video_fill_size_info(struct sk_buff *skb,
+					   struct fq_video_pkt_info *info,
+					   u32 pkt_len)
+{
+	pkt_len = ieee80211_video_effective_len(skb, pkt_len);
+	info->pkt_len = pkt_len;
+	info->size_bucket = ieee80211_video_size_bucket(pkt_len);
+	info->last_tail_candidate = pkt_len <= FQ_VIDEO_LAST_TAIL_MAX_BYTES;
+	info->has_size = true;
+}
